# ════════════════════════════════════════════
#  InAmigos Foundation — .env
#  NEVER commit this file to GitHub/Git
#  Add .env to your .gitignore
# ════════════════════════════════════════════

# MongoDB connection string
# Local:   mongodb://localhost:27017/inamigos
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/inamigos
MONGO_URI=mongodb+srv://inamigos_admin:AMigosFoundation@inamigos-cluster.umbvuor.mongodb.net/?appName=inamigos-cluster

# JWT secret — change this to a long random string in production
JWT_SECRET=replace_this_with_a_very_long_random_secret_string_123

# Server port
PORT=3000

# (Optional) UPI ID for donation page
UPI_ID=inamigosfoundation@upi

# (Optional) Formspree endpoint for volunteer form (if not using DB)
# FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID
